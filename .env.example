# Divine product web environment example
# VITE_* values are compiled into the browser bundle. Use public client values only.

# Firebase web client configuration
VITE_FIREBASE_API_KEY=<firebase_web_api_key>
VITE_FIREBASE_AUTH_DOMAIN=<firebase_auth_domain>
VITE_FIREBASE_PROJECT_ID=<firebase_project_id>
VITE_FIREBASE_STORAGE_BUCKET=<firebase_storage_bucket>
VITE_FIREBASE_MESSAGING_SENDER_ID=<firebase_messaging_sender_id>
VITE_FIREBASE_APP_ID=<firebase_web_app_id>
VITE_FIREBASE_MEASUREMENT_ID=<firebase_measurement_id_optional>
VITE_FIREBASE_APP_CHECK_SITE_KEY=<recaptcha_enterprise_site_key_optional>

# Public API and navigation configuration
VITE_GRAPHQL_API_URL=http://localhost:4000/graphql
VITE_MARKETING_URL=http://localhost:5174
VITE_ENABLE_KEEP_ALIVE=false

# Razorpay public checkout key only. Never place RAZORPAY_KEY_SECRET in frontend env.
VITE_RAZORPAY_KEY_ID=<razorpay_public_key_id>
